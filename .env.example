# ─── GitHub ───────────────────────────────────────────────
# Your GitHub username (required for repo fetch)
VITE_GITHUB_USERNAME=ray-dev

# Optional: GitHub Personal Access Token (for higher rate limits — 60/hr → 5000/hr)
# Create at: https://github.com/settings/tokens → classic → public_repo scope
VITE_GITHUB_TOKEN=

# ─── Backend URL ──────────────────────────────────────────
# URL of your deployed backend (for HackerRank live scraping)
# Local: http://localhost:5000
# Deployed (Render/Railway): https://your-backend.onrender.com
VITE_BACKEND_URL=http://localhost:5000

# ─── EmailJS ──────────────────────────────────────────────
# Get these from https://emailjs.com after creating:
#   1. An email service (Gmail / Outlook / etc.)
#   2. A template with variables: from_name, from_email, subject, message, to_name
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
